# FILE NAME: gpinitsystem_config

# Configuration file needed by the gpinitsystem

################################################
#### REQUIRED PARAMETERS
################################################

#### Naming convention for utility-generated data directories.
{% if (_cluster_count_segments | int) == 0 %}
SEG_PREFIX=gpsne
{% elif whpg_seg_prefix == "default" %}
SEG_PREFIX=gpseg
{% else %}
SEG_PREFIX={{ whpg_seg_prefix }}
{% endif %}

#### Base number by which primary segment port numbers 
#### are calculated.
PORT_BASE={{ whpg_seg_base_port }}

#### File system location(s) where primary segment data directories 
#### will be created. The number of locations in the list dictate
#### the number of primary segments that will get created per
#### physical host (if multiple addresses for a host are listed in 
#### the hostfile, the number of segments will be spread evenly across
#### the specified interface addresses).
declare -a DATA_DIRECTORY=({{ ([whpg_segment_data_directory] * whpg_seg_num) | join(' ') }})

#### OS-configured hostname or IP address of the coordinator host.
COORDINATOR_HOSTNAME=$(cat {{ _whpg_user_info.home }}/cluster_hostfile_coordinator_{{ cluster_name }})

#### File system location where the coordinator data directory 
#### will be created.
COORDINATOR_DIRECTORY={{ whpg_coordinator_data_directory }}

#### Port number for the coordinator instance. 
COORDINATOR_PORT={{ whpg_port }}

#### Shell utility used to connect to remote hosts.
TRUSTED_SHELL=ssh

#### Default server-side character set encoding.
ENCODING=UNICODE

################################################
#### OPTIONAL MIRROR PARAMETERS
################################################

{% if whpg_seg_enable_mirrors %}
#### Base number by which mirror segment port numbers
#### are calculated.
MIRROR_PORT_BASE={{ whpg_seg_mirror_base_port }}

#### File system location(s) where mirror segment data directories
#### will be created. The number of mirror locations must equal the
#### number of primary locations as specified in the
#### DATA_DIRECTORY parameter.
declare -a MIRROR_DATA_DIRECTORY=({{ ([whpg_segment_mirror_directory] * whpg_seg_num) | join(' ') }})
{% endif %}


################################################
#### OTHER OPTIONAL PARAMETERS
################################################

#### Create a database of this name after initialization.
{% if whpg_default_database is defined and whpg_default_database | length > 0 %}
DATABASE_NAME={{ whpg_default_database }}
{% else %}
#DATABASE_NAME=name_of_database
{% endif %}

#### Specify the location of the host address file here instead of
#### with the -h option of gpinitsystem.
{% if (_cluster_count_segments | int) > 0 %}
MACHINE_LIST_FILE={{ _whpg_user_info.home }}/cluster_hostfile_segments_{{ cluster_name }}
{% else %}
MACHINE_LIST_FILE={{ _whpg_user_info.home }}/cluster_hostfile_coordinator_{{ cluster_name }}
{% endif %}
